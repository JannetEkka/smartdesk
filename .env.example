# SmartDesk — Environment Variables
# Pattern from docs/adk.md — Codelab 2, "Set up environment variables"

# ADK / Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=smartdesk-492115
GOOGLE_CLOUD_LOCATION=us-central1

# Project details (auto-populated by setup/setup_env.sh)
PROJECT_ID=smartdesk-492115
PROJECT_NUMBER=your-project-number
SA_NAME=smartdesk-cr-service
SERVICE_ACCOUNT=smartdesk-cr-service@smartdesk-492115.iam.gserviceaccount.com
MODEL=gemini-2.5-flash

# AlloyDB (Track 3 — docs/alloydb.md)
# Option 1: Full DATABASE_URL (recommended, matches Codelab 2 pattern)
DATABASE_URL=postgresql+pg8000://postgres:your-password@your-alloydb-ip:5432/postgres
# Option 2: Individual variables (fallback)
# ALLOYDB_IP=your-alloydb-primary-ip
# ALLOYDB_PORT=5432
# ALLOYDB_USER=postgres
# ALLOYDB_PASSWORD=your-password
# ALLOYDB_DB=postgres

# MCP (Track 2 — docs/mcp.md)
# Gmail and Calendar use self-hosted MCP servers via StdioConnectionParams
# (see smartdesk_agent/mcp_servers/)
# No URL config needed — they run as child processes via ADK's MCPToolset.
# Just ensure you've run: gcloud auth application-default login
